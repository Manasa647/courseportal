{
  "name": "course-portal-backend",
  "version": "1.0.0",
  "description": "Express Backend for Course & Program Portal",
  "main": "dist/server.js",
  "scripts": {
    "db:switch": "node scripts/switch-db.js",
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "npm run db:switch && prisma generate",
    "prisma:migrate": "npm run db:switch && prisma migrate dev",
    "prisma:deploy": "npm run db:switch && prisma migrate deploy",
    "prisma:seed": "npm run db:switch && ts-node prisma/seed.ts",
    "prisma:push": "npm run db:switch && prisma db push",
    "test:integration": "npm run db:switch && jest --config jest.config.js --runInBand"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.4",
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
